{
  "name": "goreleaser-npm-publisher",
  "version": "1.5.0",
  "description": "Build and publish npm packages based on goreleaser output folder",
  "bin": "dist/cli.cjs",
  "main": "dist/index.cjs",
  "type": "module",
  "author": {
    "email": "evg.abramovitch@gmail.com",
    "name": "Evgeny Abramovich",
    "url": "https://github.com/evg4b"
  },
  "license": "MIT",
  "homepage": "https://github.com/evg4b/goreleaser-npm-publisher",
  "repository": {
    "type": "git",
    "url": "git@github.com:evg4b/goreleaser-npm-publisher.git"
  },
  "keywords": [
    "goreleaser",
    "npm",
    "npm-publish",
    "binary",
    "cli",
    "publish",
    "release"
  ],
  "bugs": {
    "url": "https://github.com/evg4b/goreleaser-npm-publisher/issues"
  },
  "readme": "README.md",
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "build": "NODE_ENV=production tsup",
    "build:dev": "NODE_ENV=development tsup",
    "start": "node dist/cli.cjs",
    "run": "tsup && node dist/cli.cjs",
    "format": "prettier --write .",
    "lint": "eslint .",
    "watch": "tsup --watch",
    "test": "jest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.4",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "install": "^0.13.0",
    "jest": "^30.4.2",
    "jest-esbuild": "^0.4.0",
    "prettier": "^3.9.0",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "glob": "^13.0.6",
    "lodash": "^4.18.1",
    "picocolors": "^1.1.1",
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": ">=16"
  }
}
